// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  super_admin
  company_admin
  hr_manager
  manager
  employee
}

enum CompanyStatus {
  active
  suspended
  archived
}

enum EmployeeStatus {
  active
  on_leave
  terminated
}

enum EmploymentType {
  full_time
  part_time
  contract
  intern
}

enum Gender {
  male
  female
  other
}

enum CompensationChangeType {
  initial
  increment
  decrement
  adjustment
}

model Company {
  id            String         @id @default(uuid())
  name          String         @db.VarChar(150)
  code          String?        @unique          // short code like "PHL" or "BHINV"
  logoUrl       String?
  industry      String?
  address       String?
  city          String?
  country       String?
  planExpiresAt DateTime?
  maxEmployees  Int?
  status        CompanyStatus  @default(active)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  // Relations
  users         User[]
  departments   Department[]
  designations  Designation[]
  workShifts    WorkShift[]
  employees     Employee[]
  attendanceDays AttendanceDay[]
  attendanceLogs AttendanceLog[]
  attendanceRegularizations AttendanceRegularization[]
  leaveTypes    LeaveType[]
  leaveRequests LeaveRequest[]
  complaints    Complaint[]
  complaintNotes ComplaintNote[]
  policies      Policy[]
  policyVersions PolicyVersion[]
  projects      Project[]
  projectTasks  ProjectTask[]
  projectTaskComments ProjectTaskComment[]
  compensationHistories EmployeeCompensationHistory[]

  @@index([name])
  @@index([status])
  @@index([industry])
  @@index([country])
  @@map("companies")
}

model User {
  id          String    @id @default(uuid())
  email       String    @unique
  password    String    // hashed with bcrypt
  fullName    String?
  phone       String?   @db.VarChar(20)
  avatarUrl   String?   // optional profile photo
  role        UserRole  @default(employee)
  // Multi-tenant
  companyId   String?         // null for super_admin
  company     Company?        @relation(fields: [companyId], references: [id])
  // Account status
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  employee              Employee?
  attendanceDaysCreated AttendanceDay[] @relation("AttendanceDayCreatedBy")
  attendanceDaysUpdated AttendanceDay[] @relation("AttendanceDayUpdatedBy")
  refreshTokens         RefreshToken[]
  reviewedRegularizations AttendanceRegularization[] @relation("regularizationReviewedBy")
  leaveRequestsCreated  LeaveRequest[] @relation("LeaveRequestCreatedBy")
  leaveRequestsReviewed LeaveRequest[] @relation("LeaveRequestReviewedBy")
  complaintsCreated     Complaint[] @relation("ComplaintCreatedBy")
  complaintsUpdated     Complaint[] @relation("ComplaintUpdatedBy")
  complaintNotes        ComplaintNote[]
  policiesCreated       Policy[] @relation("PolicyCreatedBy")
  policyVersionsCreated PolicyVersion[] @relation("PolicyVersionCreatedBy")
  projectsCreated       Project[] @relation("ProjectCreatedBy")
  projectsUpdated       Project[] @relation("ProjectUpdatedBy")
  projectMembersAdded   ProjectMember[] @relation("ProjectMemberAddedBy")
  projectTasksCreated   ProjectTask[] @relation("ProjectTaskCreatedBy")
  projectTasksUpdated   ProjectTask[] @relation("ProjectTaskUpdatedBy")
  projectTaskComments   ProjectTaskComment[] @relation("ProjectTaskCommentAuthor")
  compensationChanges   EmployeeCompensationHistory[] @relation("EmployeeCompensationChangedBy")

  @@index([email])
  @@index([role])
  @@index([companyId])
  @@index([isActive])
  @@index([companyId, role])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Department {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String   @db.VarChar(100)   // e.g. "Human Resources"
  code        String?  @db.VarChar(20)    // e.g. "HR", "DEV"
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // A company cannot have two departments with same name/code
  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId, isActive])
  employees     Employee[]
  @@map("departments")
}

model Designation {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String   @db.VarChar(100)   // e.g. "Software Engineer", "Senior Manager"
  code        String?  @db.VarChar(20)    // e.g. "SE", "SM", "HR_EXEC"
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // A company cannot have two designations with same name/code
  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId, isActive])
  employees     Employee[]
  @@map("designations")
}

model WorkShift {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String   @db.VarChar(100)
  code        String?  @db.VarChar(20)
  description String?
  startTime   DateTime @db.Time
  endTime     DateTime @db.Time
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId, isActive])
  employees      Employee[]
  attendanceDays AttendanceDay[]
  @@map("work_shifts")
}

model Employee {
  id            String         @id @default(uuid())
  // Relations
  userId        String         @unique
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company        @relation(fields: [companyId], references: [id])
  departmentId  String?
  department    Department?    @relation(fields: [departmentId], references: [id])
  designationId String?
  designation   Designation?   @relation(fields: [designationId], references: [id])
  workShiftId   String?
  workShift     WorkShift?     @relation(fields: [workShiftId], references: [id])
  
  // Core HR identity
  employeeCode  String         // e.g. "EMP-0001"
  firstName     String         @db.VarChar(80)
  lastName      String         @db.VarChar(80)
  middleName    String?        @db.VarChar(80)
  gender        Gender?
  dateOfBirth   DateTime?
  
  // Job & employment
  joinDate        DateTime?
  probationEnd    DateTime?
  employmentType  EmploymentType?
  locationId      String?              // (optional future relation to CompanyLocation)
  
  // Contacts
  workEmail      String?
  personalEmail  String?
  phone          String?        @db.VarChar(20)
  address        String?
  emergencyContactName  String?
  emergencyContactPhone String? @db.VarChar(20)
  
  // Profile image
  imageUrl     String?                 // e.g. "employees/emp-0001.jpg" or full CDN URL
  
  // Payroll starter fields
  baseSalary   Float?
  allowances   Float?   @default(0)
  isMarried    Boolean  @default(false)
  
  // Status & audit
  status       EmployeeStatus @default(active)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Relations
  attendanceDays AttendanceDay[]
  attendanceLogs AttendanceLog[]
  attendanceRegularizations AttendanceRegularization[]
  leaveRequests LeaveRequest[]
  complaints    Complaint[]
  policyAcceptances PolicyAcceptance[]
  projectMemberships ProjectMember[]
  assignedProjectTasks ProjectTask[] @relation("ProjectTaskAssignee")
  compensationHistory EmployeeCompensationHistory[]

  @@unique([companyId, employeeCode])        // code unique per company
  @@index([companyId])
  @@index([companyId, departmentId])
  @@index([companyId, designationId])
  @@index([companyId, workShiftId])
  @@index([companyId, status])
  @@index([companyId, employmentType])
  @@map("employees")
}

enum AttendanceStatus {
  PRESENT
  LATE
  HALF_DAY
  ABSENT
  ON_LEAVE
  WEEKEND
  HOLIDAY
}

enum AttendanceSource {
  SELF
  ADMIN
  IMPORT
}

enum AttendanceLogType {
  CHECK_IN
  CHECK_OUT
}

enum AttendanceLogMethod {
  WEB
  ADMIN
  IMPORT
}

enum RegularizationRequestType {
  MISSED_CHECKIN
  MISSED_CHECKOUT
  WRONG_TIME
  FULL_DAY_EDIT
}

enum RegularizationStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum HalfDaySession {
  FIRST_HALF
  SECOND_HALF
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum ComplaintPriority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ProjectTaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum ProjectTaskPriority {
  LOW
  MEDIUM
  HIGH
}

model AttendanceDay {
  id               String           @id @default(uuid())
  companyId        String
  company          Company          @relation(fields: [companyId], references: [id])
  employeeId       String
  employee         Employee         @relation(fields: [employeeId], references: [id])
  workShiftId      String?
  workShift        WorkShift?       @relation(fields: [workShiftId], references: [id])
  date             DateTime         // stored as UTC start-of-day
  checkInTime      DateTime?
  checkOutTime     DateTime?
  totalWorkMinutes Int              @default(0)
  lateMinutes      Int              @default(0)
  overtimeMinutes  Int              @default(0)
  status           AttendanceStatus
  source           AttendanceSource @default(SELF)
  notes            String?
  createdById      String?
  createdBy        User?            @relation("AttendanceDayCreatedBy", fields: [createdById], references: [id])
  updatedById      String?
  updatedBy        User?            @relation("AttendanceDayUpdatedBy", fields: [updatedById], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  logs             AttendanceLog[]
  regularizations  AttendanceRegularization[]

  @@unique([employeeId, date])
  @@index([companyId, date])
  @@index([companyId, employeeId, date])
  @@map("attendance_days")
}

model AttendanceLog {
  id          String              @id @default(uuid())
  companyId   String
  company     Company             @relation(fields: [companyId], references: [id])
  employeeId  String
  employee    Employee            @relation(fields: [employeeId], references: [id])
  attendanceDayId String?
  attendanceDay   AttendanceDay?  @relation(fields: [attendanceDayId], references: [id])
  timestamp   DateTime
  type        AttendanceLogType
  method      AttendanceLogMethod
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime            @default(now())

  @@index([companyId, employeeId, timestamp])
  @@map("attendance_logs")
}

model AttendanceRegularization {
  id                   String                   @id @default(uuid())
  companyId            String
  company              Company                  @relation(fields: [companyId], references: [id])
  employeeId           String
  employee             Employee                 @relation(fields: [employeeId], references: [id])
  attendanceDayId      String?
  attendanceDay        AttendanceDay?           @relation(fields: [attendanceDayId], references: [id])
  date                 DateTime
  requestType          RegularizationRequestType
  requestedCheckInTime DateTime?
  requestedCheckOutTime DateTime?
  reason               String
  status               RegularizationStatus     @default(PENDING)
  reviewedBy           String?
  reviewedByUser       User?                    @relation("regularizationReviewedBy", fields: [reviewedBy], references: [id])
  reviewedAt           DateTime?
  reviewNote           String?
  beforeSnapshot       Json?
  afterSnapshot        Json?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  @@index([companyId, employeeId, date])
  @@index([status, date])
  @@map("attendance_regularizations")
}

model LeaveType {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  name        String   @db.VarChar(100)
  code        String?  @db.VarChar(20)
  description String?
  allocatedDays Float  @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  leaveRequests LeaveRequest[]

  @@unique([companyId, name])
  @@unique([companyId, code])
  @@index([companyId, isActive])
  @@map("leave_types")
}

model LeaveRequest {
  id           String      @id @default(uuid())
  companyId    String
  company      Company     @relation(fields: [companyId], references: [id])
  employeeId   String
  employee     Employee    @relation(fields: [employeeId], references: [id])
  leaveTypeId  String
  leaveType    LeaveType   @relation(fields: [leaveTypeId], references: [id])
  startDate    DateTime
  endDate      DateTime
  totalDays    Float
  isHalfDay    Boolean     @default(false)
  halfDaySession HalfDaySession?
  reason       String
  status       LeaveStatus @default(PENDING)
  createdById  String?
  createdBy    User?       @relation("LeaveRequestCreatedBy", fields: [createdById], references: [id])
  reviewedById String?
  reviewedBy   User?       @relation("LeaveRequestReviewedBy", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([companyId, employeeId, startDate])
  @@index([companyId, status])
  @@map("leave_requests")
}

model Complaint {
  id          String            @id @default(uuid())
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id])
  employeeId  String
  employee    Employee          @relation(fields: [employeeId], references: [id])
  title       String            @db.VarChar(200)
  description String
  priority    ComplaintPriority @default(MEDIUM)
  status      ComplaintStatus   @default(OPEN)
  closedAt    DateTime?
  createdById String?
  createdBy   User?             @relation("ComplaintCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?             @relation("ComplaintUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  notes       ComplaintNote[]

  @@index([companyId, status])
  @@index([companyId, priority])
  @@index([companyId, employeeId, createdAt])
  @@map("complaints")
}

model ComplaintNote {
  id           String    @id @default(uuid())
  complaintId  String
  complaint    Complaint @relation(fields: [complaintId], references: [id], onDelete: Cascade)
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  authorUserId String
  authorUser   User      @relation(fields: [authorUserId], references: [id])
  note         String
  createdAt    DateTime  @default(now())

  @@index([complaintId, createdAt])
  @@index([companyId, createdAt])
  @@map("complaint_notes")
}

model Policy {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  title       String   @db.VarChar(200)
  isActive    Boolean  @default(true)
  createdById String?
  createdBy   User?    @relation("PolicyCreatedBy", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions    PolicyVersion[]

  @@index([companyId, isActive])
  @@index([companyId, createdAt])
  @@map("policies")
}

model PolicyVersion {
  id            String   @id @default(uuid())
  policyId      String
  policy        Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  version       String   @db.VarChar(30)
  content       String
  effectiveFrom DateTime
  createdById   String?
  createdBy     User?    @relation("PolicyVersionCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime @default(now())

  acceptances   PolicyAcceptance[]

  @@unique([policyId, version])
  @@index([companyId, createdAt])
  @@index([policyId, effectiveFrom])
  @@map("policy_versions")
}

model PolicyAcceptance {
  id              String        @id @default(uuid())
  employeeId      String
  employee        Employee      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  policyVersionId String
  policyVersion   PolicyVersion @relation(fields: [policyVersionId], references: [id], onDelete: Cascade)
  acceptedAt      DateTime      @default(now())
  createdAt       DateTime      @default(now())

  @@unique([employeeId, policyVersionId])
  @@index([employeeId, acceptedAt])
  @@index([policyVersionId, acceptedAt])
  @@map("policy_acceptances")
}

model Project {
  id          String        @id @default(uuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id])
  name        String        @db.VarChar(150)
  description String?
  startDate   DateTime?
  endDate     DateTime?
  status      ProjectStatus @default(ACTIVE)
  createdById String?
  createdBy   User?         @relation("ProjectCreatedBy", fields: [createdById], references: [id])
  updatedById String?
  updatedBy   User?         @relation("ProjectUpdatedBy", fields: [updatedById], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members     ProjectMember[]
  tasks       ProjectTask[]

  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@map("projects")
}

model ProjectMember {
  id         String    @id @default(uuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  addedById  String?
  addedBy    User?     @relation("ProjectMemberAddedBy", fields: [addedById], references: [id])
  createdAt  DateTime  @default(now())

  @@unique([projectId, employeeId])
  @@index([projectId])
  @@index([employeeId])
  @@map("project_members")
}

model ProjectTask {
  id                 String              @id @default(uuid())
  projectId          String
  project            Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  companyId          String
  company            Company             @relation(fields: [companyId], references: [id])
  title              String              @db.VarChar(200)
  description        String?
  status             ProjectTaskStatus   @default(TODO)
  priority           ProjectTaskPriority @default(MEDIUM)
  dueDate            DateTime?
  assigneeEmployeeId String?
  assigneeEmployee   Employee?           @relation("ProjectTaskAssignee", fields: [assigneeEmployeeId], references: [id])
  createdById        String?
  createdBy          User?               @relation("ProjectTaskCreatedBy", fields: [createdById], references: [id])
  updatedById        String?
  updatedBy          User?               @relation("ProjectTaskUpdatedBy", fields: [updatedById], references: [id])
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  comments           ProjectTaskComment[]

  @@index([projectId, status, updatedAt])
  @@index([companyId, assigneeEmployeeId])
  @@index([dueDate])
  @@map("project_tasks")
}

model ProjectTaskComment {
  id           String      @id @default(uuid())
  taskId        String
  task          ProjectTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  companyId     String
  company       Company     @relation(fields: [companyId], references: [id])
  authorUserId  String
  authorUser    User        @relation("ProjectTaskCommentAuthor", fields: [authorUserId], references: [id])
  comment       String
  createdAt     DateTime    @default(now())

  @@index([taskId, createdAt])
  @@index([companyId, createdAt])
  @@map("project_task_comments")
}

model EmployeeCompensationHistory {
  id                  String                 @id @default(uuid())
  employeeId          String
  employee            Employee               @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  companyId           String
  company             Company                @relation(fields: [companyId], references: [id])
  previousBaseSalary  Float?
  newBaseSalary       Float?
  previousAllowances  Float?
  newAllowances       Float?
  changeType          CompensationChangeType @default(adjustment)
  effectiveFrom       DateTime               @default(now())
  changedAt           DateTime               @default(now())
  changedById         String?
  changedBy           User?                  @relation("EmployeeCompensationChangedBy", fields: [changedById], references: [id])
  notes               String?

  @@index([employeeId, changedAt])
  @@index([companyId, changedAt])
  @@map("employee_compensation_history")
}
